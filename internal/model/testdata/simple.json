{
  "version": "0.2.0.dev0",
  "semantic_model": [
    {
      "name": "simple_sales",
      "description": "Minimal valid model with one dataset, one dimension, one metric.",
      "ai_context": {
        "instructions": "Use this model for revenue-by-region questions.",
        "synonyms": ["sales model"]
      },
      "datasets": [
        {
          "name": "orders",
          "source": "analytics.public.orders",
          "primary_key": ["order_id"],
          "fields": [
            {
              "name": "region",
              "expression": {
                "dialects": [
                  { "dialect": "ANSI_SQL", "expression": "region" }
                ]
              },
              "dimension": { "is_time": false },
              "ai_context": "Geographic sales region."
            }
          ]
        }
      ],
      "metrics": [
        {
          "name": "revenue",
          "description": "Total revenue.",
          "expression": {
            "dialects": [
              { "dialect": "ANSI_SQL", "expression": "SUM(orders.amount)" }
            ]
          }
        }
      ]
    }
  ]
}
